// Prisma schema for Vendor Service

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/vendor-client"
}

datasource db {
  provider = "postgresql"
}

model Vendor {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  company   String
  phone     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vendors")
}
