# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ===========================================
# API Configuration
# ===========================================
# Base URL for the API server
API_BASE_URL=http://localhost:3000/api

# API timeout in milliseconds
API_TIMEOUT=30000

# ===========================================
# Application Configuration
# ===========================================
# Node environment (development, production, test)
NODE_ENV=development

# Application port numbers
SHOP_PORT=4200
API_PORT=3000

# ===========================================
# Authentication & Security
# ===========================================
# JWT secret key for token generation
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT token expiration time (e.g., "1h", "7d", "30d")
JWT_EXPIRATION=7d

# Refresh token expiration time
REFRESH_TOKEN_EXPIRATION=30d

# Cookie security settings
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ===========================================
# Database Configuration
# ===========================================
# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/my_mall_db

# Redis cache URL
REDIS_URL=redis://localhost:6379

# ===========================================
# Payment Gateway
# ===========================================
# Stripe API keys (if using Stripe)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal configuration (if using PayPal)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ===========================================
# Email Service
# ===========================================
# Email service provider (e.g., SendGrid, Mailgun)
EMAIL_SERVICE_PROVIDER=sendgrid
EMAIL_API_KEY=your_email_api_key
EMAIL_FROM_ADDRESS=noreply@my-mall.com
EMAIL_FROM_NAME=My Mall

# ===========================================
# File Storage
# ===========================================
# AWS S3 configuration (if using S3 for images)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=my-mall-assets

# ===========================================
# Analytics & Monitoring
# ===========================================
# Google Analytics tracking ID
GA_TRACKING_ID=UA-XXXXXXXXX-X

# Application Insights (Azure) instrumentation key
APPINSIGHTS_INSTRUMENTATION_KEY=your_instrumentation_key

# Sentry DSN for error tracking
SENTRY_DSN=your_sentry_dsn

# ===========================================
# Feature Flags
# ===========================================
# Enable/disable features
ENABLE_PRODUCT_REVIEWS=true
ENABLE_WISHLIST=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_GUEST_CHECKOUT=true

# ===========================================
# Internationalization
# ===========================================
# Default language
DEFAULT_LANGUAGE=en

# Supported languages (comma-separated)
SUPPORTED_LANGUAGES=en,he

# ===========================================
# Rate Limiting
# ===========================================
# Rate limit window in milliseconds
RATE_LIMIT_WINDOW=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# CORS Configuration
# ===========================================
# Allowed origins (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:4200

# ===========================================
# Logging
# ===========================================
# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable/disable request logging
LOG_REQUESTS=true
